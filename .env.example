# Frontend Environment Variables
# Copy this to .env.local for local development
# Copy to .env.production for production

# Local Development (default, don't set this - uses localhost)
# VITE_API_URL=http://localhost:5000/api

# Production (set to your backend public URL)
# VITE_API_URL=https://your-backend-domain.com/api

# Examples:
# VITE_API_URL=https://ai-resume-backend.onrender.com/api
# VITE_API_URL=https://api-production-backend.up.railway.app/api
# VITE_API_URL=https://backend.yourdomain.com/api
